function [gripperStatus, currentConfig, stop] = main(pickTraj, placeTraj, targetGrasped, startGrasp)coder.extrinsic('evalin');coder.extrinsic('assignin');coder.extrinsic('record_grasp_failure_runtime');stop = false;gripperStatus = 0; % 0 = Open; 1 = Closepersistent index delay statepersistent lastPickFp lastPlaceFppersistent frameCountpersistent waitStableCountpersistent viewMoveTraj viewMoveIndex viewMoveModepersistent holdConfig holdValidpersistent startupMoveDonepersistent grabHoldCountif isempty(index)    index = 1;endif isempty(delay)    delay = 1;endif isempty(state)    state = 0;endif isempty(lastPickFp)    lastPickFp = nan(1,4);endif isempty(lastPlaceFp)    lastPlaceFp = nan(1,4);endif isempty(frameCount)    frameCount = 0;endif isempty(waitStableCount)    waitStableCount = uint16(0);endif isempty(viewMoveTraj)    viewMoveTraj = zeros(6,1);endif isempty(viewMoveIndex)    viewMoveIndex = 1;endif isempty(viewMoveMode)    viewMoveMode = uint8(0);   % 0=none, 1=switch_view, 2=return_home_after_dropendif isempty(holdConfig)    holdConfig = zeros(6,1);endif isempty(holdValid)    holdValid = false;endif isempty(startupMoveDone)    startupMoveDone = false;endif isempty(grabHoldCount)    grabHoldCount = uint16(0);endframeCount = frameCount + 1;% state:% 0 = WAIT% 1 = PICK% 2 = GRAB% 3 = PLACE% 4 = DROP% 5 = END% 6 = VIEW_MOVE% 7 = DROP_SETTLE%     mode 1 = switch_view%     mode 2 = return_home_after_drop%     mode 3 = startup_move_to_ADROP_SETTLE_TICKS = 20;nPick  = size(pickTraj, 2);nPlace = size(placeTraj, 2);% 默认保持当前位置currentConfig = pickTraj(:,1);% =========================================================% 轨迹指纹：用于判断传??main 的轨迹是不是变了% =========================================================pickFp  = trajFingerprint(pickTraj);placeFp = trajFingerprint(placeTraj);pickChanged  = any(abs(pickFp  - lastPickFp)  > 1e-9);placeChanged = any(abs(placeFp - lastPlaceFp) > 1e-9);% 只在变化时报??if pickChanged    % dbgprintf('[main][WARN] pickTraj changed at frame=%d state=%s index=%d/%d fp=[%.6f %.6f %.6f %.6f]\n', ...    %    int32(frameCount), stateName(state), int32(index), int32(nPick), ...    %    pickFp(1), pickFp(2), pickFp(3), pickFp(4));endif placeChanged    % dbgprintf('[main][WARN] placeTraj changed at frame=%d state=%s index=%d/%d fp=[%.6f %.6f %.6f %.6f]\n', ...    %    int32(frameCount), stateName(state), int32(index), int32(nPlace), ...    %    placeFp(1), placeFp(2), placeFp(3), placeFp(4));endlastPickFp  = pickFp;lastPlaceFp = placeFp;% dbgprintf('[main] state=%s startGrasp=%d targetGrasped=%d index=%d delay=%d\n', ...%    stateName(state), int32(logical(startGrasp)), int32(logical(targetGrasped)), ...%    int32(index), int32(delay));% Publish loop readiness for auto-trigger logic.canPick = false;if state == 0    if waitStableCount < uint16(65535)        waitStableCount = waitStableCount + uint16(1);    end    canPick = (waitStableCount >= uint16(20)); % settle at home before next detection/latchelse    waitStableCount = uint16(0);endassignin('base', 'USER_CAN_PICK', canPick);% -------------------------% WAIT：未确认前不动作% -------------------------if state == 0    gripperStatus = 0;    assignin('base', 'USER_VISION_ENABLE', true);    grabHoldCount = uint16(0);    if holdValid        currentConfig = holdConfig;    else        currentConfig = pickTraj(:,1);        holdConfig = currentConfig;    end    % dbgprintf('[main] WAIT hold pickTraj step 1/%d\n', int32(nPick));    % -------------------------------------------------    % 启动时：执行 interpCols(qHome, A, 120)    % 其中 qHome = pickTraj(:,1), A = USER_QHOME_CURRENT（由 USER_VIEW_IDX 决定??    % -------------------------------------------------    if ~startupMoveDone        qHome0 = pickTraj(:,1);   % 启动当前 qHome        qA = zeros(6,1);        dbgprintf('=== workspace debug at startup ===\n');                evalin('base', [ ...            'fprintf(''exist(USER_VIEW_POSES) = %d\n'', exist(''USER_VIEW_POSES'',''var''));' ...            'if exist(''USER_VIEW_POSES'',''var'') ~= 0,' ...            '  fprintf(''size(USER_VIEW_POSES) = [%d %d]\n'', size(USER_VIEW_POSES,1), size(USER_VIEW_POSES,2));' ...            '  if size(USER_VIEW_POSES,1) >= 6 && size(USER_VIEW_POSES,2) >= 1,' ...            '    fprintf(''USER_VIEW_POSES(:,1) = [%.6f %.6f %.6f %.6f %.6f %.6f]\n'', USER_VIEW_POSES(1,1), USER_VIEW_POSES(2,1), USER_VIEW_POSES(3,1), USER_VIEW_POSES(4,1), USER_VIEW_POSES(5,1), USER_VIEW_POSES(6,1));' ...            '  end;' ...            'end;' ...        ]);                evalin('base', [ ...            'fprintf(''exist(USER_QHOME_CURRENT) = %d\n'', exist(''USER_QHOME_CURRENT'',''var''));' ...            'if exist(''USER_QHOME_CURRENT'',''var'') ~= 0,' ...            '  fprintf(''USER_QHOME_CURRENT = [%.6f %.6f %.6f %.6f %.6f %.6f]\n'', USER_QHOME_CURRENT(1), USER_QHOME_CURRENT(2), USER_QHOME_CURRENT(3), USER_QHOME_CURRENT(4), USER_QHOME_CURRENT(5), USER_QHOME_CURRENT(6));' ...            'end;' ...        ]);                evalin('base', [ ...            'fprintf(''exist(USER_QHOME_NEXT) = %d\n'', exist(''USER_QHOME_NEXT'',''var''));' ...            'if exist(''USER_QHOME_NEXT'',''var'') ~= 0,' ...            '  fprintf(''USER_QHOME_NEXT = [%.6f %.6f %.6f %.6f %.6f %.6f]\n'', USER_QHOME_NEXT(1), USER_QHOME_NEXT(2), USER_QHOME_NEXT(3), USER_QHOME_NEXT(4), USER_QHOME_NEXT(5), USER_QHOME_NEXT(6));' ...            'end;' ...        ]);                evalin('base', [ ...            'fprintf(''exist(USER_VIEW_IDX) = %d\n'', exist(''USER_VIEW_IDX'',''var''));' ...            'if exist(''USER_VIEW_IDX'',''var'') ~= 0,' ...            '  fprintf(''USER_VIEW_IDX = %.0f\n'', double(USER_VIEW_IDX));' ...            'end;' ...        ]);                evalin('base', [ ...            'fprintf(''exist(USER_VIEW_COUNT) = %d\n'', exist(''USER_VIEW_COUNT'',''var''));' ...            'if exist(''USER_VIEW_COUNT'',''var'') ~= 0,' ...            '  fprintf(''USER_VIEW_COUNT = %.0f\n'', double(USER_VIEW_COUNT));' ...            'end;' ...        ]);                evalin('base', [ ...            'fprintf(''exist(USER_RESET_TOKEN) = %d\n'', exist(''USER_RESET_TOKEN'',''var''));' ...            'if exist(''USER_RESET_TOKEN'',''var'') ~= 0,' ...            '  fprintf(''USER_RESET_TOKEN = %.0f\n'', double(USER_RESET_TOKEN));' ...            'end;' ...        ]);            tmpExist = 0;        tmpExist = evalin('base', 'exist(''USER_QHOME_CURRENT'',''var'')');        if tmpExist ~= 0            qA = evalin('base', 'USER_QHOME_CURRENT');                if numel(qA) == 6                dbgprintf('--- startup move debug ---\n');                dbgprintf('qHome0 = [%.6f %.6f %.6f %.6f %.6f %.6f]\n', ...                    qHome0(1), qHome0(2), qHome0(3), qHome0(4), qHome0(5), qHome0(6));                dbgprintf('qA     = [%.6f %.6f %.6f %.6f %.6f %.6f]\n', ...                    qA(1), qA(2), qA(3), qA(4), qA(5), qA(6));                    if any(abs(qHome0(:) - qA(:)) > 1e-6)                    viewMoveTraj = interpCols(qHome0(:), qA(:), 120);                    viewMoveIndex = 1;                    viewMoveMode = uint8(3);   % startup_move_qHome_to_A                    holdValid = false;                    state = 6;                    startupMoveDone = true;                    waitStableCount = uint16(0);                        return;                else                    holdConfig = qA(:);                    holdValid = true;                    startupMoveDone = true;                end            end        end    end    % -------------------------------------------------    % 优先处理观察位切换：从当前姿态平滑移动到 USER_QHOME_NEXT    % -------------------------------------------------    hasPending = false;    qNext = zeros(6,1);    tmpExist = 0;    tmpPending = false;        tmpExist = evalin('base', 'exist(''USER_VIEW_MOVE_PENDING'',''var'')');    if tmpExist ~= 0        tmpPending = evalin('base', 'USER_VIEW_MOVE_PENDING');        hasPending = logical(tmpPending);    end    if hasPending        tmpExist = 0;                tmpExist = evalin('base', 'exist(''USER_QHOME_NEXT'',''var'')');        if tmpExist ~= 0            qNext = evalin('base', 'USER_QHOME_NEXT');        end        if isnumeric(qNext) && numel(qNext) == 6 && all(isfinite(qNext(:)))            qStart = holdConfig(:);   % 当前姿态作为起??            nMove = 120;                 % 平滑移动步数，可自行调大/调小            viewMoveTraj = interpCols(qStart, qNext(:), nMove);            viewMoveIndex = 1;            viewMoveMode = uint8(1);            holdValid = false;            state = 6;            waitStableCount = uint16(0);            % dbgprintf('[main] WAIT->VIEW_MOVE triggered\n');            return;        end    end    if startGrasp        assignin('base', 'USER_VISION_ENABLE', false);        holdValid = false;        holdConfig = pickTraj(:,1);        % dbgprintf('[main] WAIT->PICK triggered\n');        state = 1;        index = 1;        delay = 1;        waitStableCount = uint16(0);    end    return;end% -------------------------% PICK% -------------------------if state == 1    gripperStatus = 0;    assignin('base', 'USER_VISION_ENABLE', false);    currentConfig = pickTraj(:, index);    holdConfig = currentConfig;    % dbgprintf('[main] EXEC pickTraj step %d/%d\n', int32(index), int32(nPick));    index = index + 1;    if index > nPick        % dbgprintf('[main] PICK->GRAB\n');        state = 2;        index = nPick;  % 保持??pickTraj 最后一??    end% -------------------------% GRAB% -------------------------elseif state == 2    assignin('base', 'USER_VISION_ENABLE', false);    gripperStatus = 1;    currentConfig = pickTraj(:, index);    if grabHoldCount < uint16(65535)        grabHoldCount = grabHoldCount + uint16(1);    end    if targetGrasped        state = 3;        index = 1;        grabHoldCount = uint16(0);    else        grabTimeoutFrames = uint16(180);                tmpExist = double(0);        tmpExist = evalin('base', 'double(exist(''USER_GRAB_TIMEOUT_FRAMES'',''var''))');                if tmpExist ~= 0            t = double(180);            t = evalin('base', 'double(USER_GRAB_TIMEOUT_FRAMES)');                    if isfinite(t) && t >= 10                if t > 1000                    t = 1000;                end                grabTimeoutFrames = uint16(round(t));            end        end        if grabHoldCount >= grabTimeoutFrames            record_grasp_failure_runtime();            qStart = currentConfig(:);            qHomeNow = pickTraj(:,1);            nMove = 120;            viewMoveTraj = interpCols(qStart, qHomeNow(:), nMove);            viewMoveIndex = 1;            viewMoveMode = uint8(2);            gripperStatus = 0;            state = 6;            index = 1;            delay = 1;            grabHoldCount = uint16(0);            waitStableCount = uint16(0);            return;        end    end% -------------------------% PLACE% -------------------------elseif state == 3    gripperStatus = 1;    assignin('base', 'USER_VISION_ENABLE', false);    currentConfig = placeTraj(:, index);    holdConfig = currentConfig;    % dbgprintf('[main] EXEC placeTraj step %d/%d\n', int32(index), int32(nPlace));    index = index + 1;    if index > nPlace        % dbgprintf('[main] PLACE->DROP_SETTLE\n');        state = 7;        index = nPlace; % 保持??placeTraj 最后一??        delay = 1;    end% -------------------------% DROP_SETTLE% -------------------------elseif state == 7    gripperStatus = 1;    assignin('base', 'USER_VISION_ENABLE', false);    currentConfig = placeTraj(:, index);    holdConfig = currentConfig;    % dbgprintf('[main] EXEC DROP_SETTLE hold placeTraj step %d/%d delay=%d\\n', ...    %    int32(index), int32(nPlace), int32(delay));    if delay <= DROP_SETTLE_TICKS        delay = delay + 1;    else        % dbgprintf('[main] DROP_SETTLE->DROP\\n');        state = 4;    end% -------------------------% DROP% -------------------------elseif state == 4    gripperStatus = 0;    assignin('base', 'USER_VISION_ENABLE', false);    currentConfig = placeTraj(:, index);    holdConfig = currentConfig;    % dbgprintf('[main] EXEC DROP hold placeTraj step %d/%d\n', ...    %    int32(index), int32(nPlace));    state = 5;    delay = 1;% -------------------------% END% -------------------------elseif state == 5    gripperStatus = 0;    assignin('base', 'USER_VISION_ENABLE', false);    currentConfig = placeTraj(:, index);    holdConfig = currentConfig;    % dbgprintf('[main] EXEC END hold placeTraj step %d/%d delay=%d\n', ...    %    int32(index), int32(nPlace), int32(delay));    % Keep gripper open for a short time to release object stably.    if delay <= 30        delay = delay + 1;        return;    end    cubePlaceMode = double(0);    tmpExist = double(0);    tmpExist = evalin('base', 'double(exist(''USER_CUBE_PLACE_MODE'',''var''))');    if tmpExist ~= 0        cubePlaceMode = evalin('base', 'double(USER_CUBE_PLACE_MODE)');    end    if cubePlaceMode == 1        resetToken = double(0);        resetToken = evalin('base', 'double(USER_RESET_TOKEN)');        assignin('base', 'USER_CUBE_SECOND_HOME', currentConfig);        assignin('base', 'USER_CUBE_USE_SECOND_HOME', true);        assignin('base', 'USER_RESET_TOKEN', resetToken + 1);        assignin('base', 'USER_AUTO_NEED_RESET', false);        assignin('base', 'USER_PROCEED', false);        assignin('base', 'USER_ABORT', false);        assignin('base', 'USER_VISION_ENABLE', false);        holdConfig = currentConfig;        holdValid = true;        state = 0;        index = 1;        delay = 1;        waitStableCount = uint16(0);        return;    end    % Advance reset token so TargetSelect/Planner clear latch and replan.    % resetToken = double(0);    % resetToken = evalin('base', 'double(USER_RESET_TOKEN)');    % assignin('base', 'USER_RESET_TOKEN', resetToken + 1);    % assignin('base', 'USER_AUTO_NEED_RESET', false);    % assignin('base', 'USER_PROCEED', false);    % assignin('base', 'USER_ABORT', false);    % ---------------------------------------------    % 不要直接 END->WAIT    % 改成从当前放置位平滑返回到当前观察位 / home ??    % ---------------------------------------------    qStart = holdConfig(:);    qHomeNow = pickTraj(:,1);    nMove = 120;    if isnumeric(qHomeNow) && numel(qHomeNow) == 6 && all(isfinite(qHomeNow(:)))        viewMoveTraj = interpCols(qStart, qHomeNow(:), nMove);        viewMoveIndex = 1;        viewMoveMode = uint8(2);   % return_home_after_drop        holdValid = false;        state = 6;        index = 1;        delay = 1;        waitStableCount = uint16(0);        % dbgprintf('[main] END->VIEW_MOVE return to home\n');        return;    end    % 理论上不会走到这里；兜底    stop = false;    state = 0;    index = 1;    delay = 1;    % dbgprintf('[main] END->WAIT fallback\n');% -------------------------% VIEW_MOVE% -------------------------elseif state == 6    gripperStatus = 0;    assignin('base', 'USER_VISION_ENABLE', false);    currentConfig = viewMoveTraj(:, viewMoveIndex);    holdConfig = currentConfig;    % dbgprintf('[main] EXEC VIEW_MOVE step %d/%d mode=%d\n', ...    %    int32(viewMoveIndex), int32(size(viewMoveTraj, 2)), int32(viewMoveMode));    viewMoveIndex = viewMoveIndex + 1;    if viewMoveIndex > size(viewMoveTraj, 2)        currentConfig = viewMoveTraj(:, end);        holdConfig = currentConfig;        holdValid = true;        if viewMoveMode == uint8(1)            assignin('base', 'USER_QHOME_CURRENT', currentConfig(:));                    tmpExist = 0;            idxNext = 0;                    tmpExist = evalin('base', 'exist(''USER_VIEW_IDX_NEXT'',''var'')');            if tmpExist ~= 0                idxNext = evalin('base', 'USER_VIEW_IDX_NEXT');                assignin('base', 'USER_VIEW_IDX', double(idxNext));            end                    assignin('base', 'USER_VIEW_MOVE_PENDING', false);            % dbgprintf('[main] VIEW_MOVE done: switch_view\n');                elseif viewMoveMode == uint8(2)            resetToken = double(0);            resetToken = evalin('base', 'double(USER_RESET_TOKEN)');            assignin('base', 'USER_RESET_TOKEN', resetToken + 1);            assignin('base', 'USER_AUTO_NEED_RESET', false);            assignin('base', 'USER_PROCEED', false);            assignin('base', 'USER_ABORT', false);                    % dbgprintf('[main] VIEW_MOVE done: return_home_after_drop\n');                elseif viewMoveMode == uint8(3)            assignin('base', 'USER_QHOME_CURRENT', currentConfig(:));            % dbgprintf('[main] VIEW_MOVE done: startup_move_to_A\n');        end        assignin('base', 'USER_VISION_ENABLE', true);        state = 0;        viewMoveIndex = 1;        viewMoveMode = uint8(0);        waitStableCount = uint16(0);    endendendfunction fp = trajFingerprint(traj)% 用少量统计量作为轨迹指纹% 只要轨迹内容变了，指纹大概率会变fp = zeros(1,4);fp(1) = sum(traj(:));fp(2) = sum(traj(:).^2);fp(3) = sum(traj(:,1));fp(4) = sum(traj(:,end));endfunction name = stateName(state)switch state    case 0        name = 'WAIT';    case 1        name = 'PICK';    case 2        name = 'GRAB';    case 3        name = 'PLACE';    case 4        name = 'DROP';    case 5        name = 'END';    case 6        name = 'VIEW_MOVE';    case 7        name = 'DROP_SETTLE';    otherwise        name = 'UNKNOWN';endendfunction dbgprintf(varargin)coder.extrinsic('fprintf');fprintf(varargin{:});endfunction traj = interpCols(qA, qB, n)qA = qA(:);qB = qB(:);if n <= 1    traj = qB(:);    return;endtraj = zeros(length(qA), n);for i = 1:n    alpha = (i-1)/(n-1);    traj(:,i) = (1-alpha)*qA + alpha*qB;endend