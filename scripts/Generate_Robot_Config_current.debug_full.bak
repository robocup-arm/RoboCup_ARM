function [gripperStatus, currentConfig, stop] = main(pickTraj, placeTraj, targetGrasped, startGrasp)
%#codegen
coder.extrinsic('evalin');
coder.extrinsic('assignin');

stop = false;
gripperStatus = 0;

persistent state index delay waitStableCount viewMoveTraj viewMoveIndex viewMoveMode holdConfig holdValid

if isempty(state)
    state = uint8(0);
end
if isempty(index)
    index = int32(1);
end
if isempty(delay)
    delay = int32(1);
end
if isempty(waitStableCount)
    waitStableCount = uint16(0);
end
if isempty(viewMoveTraj)
    viewMoveTraj = zeros(6,120);
end
if isempty(viewMoveIndex)
    viewMoveIndex = int32(1);
end
if isempty(viewMoveMode)
    viewMoveMode = uint8(0);
end
if isempty(holdConfig)
    holdConfig = zeros(6,1);
end
if isempty(holdValid)
    holdValid = false;
end

DROP_SETTLE_TICKS = int32(20);
OPEN_SETTLE_TICKS = int32(30);
RETURN_STEPS = int32(120);

nPick = int32(size(pickTraj, 2));
nPlace = int32(size(placeTraj, 2));

currentConfig = pickTraj(:,1);

canPick = false;
if state == uint8(0)
    if waitStableCount < uint16(65535)
        waitStableCount = waitStableCount + uint16(1);
    end
    canPick = (waitStableCount >= uint16(20));
else
    waitStableCount = uint16(0);
end
assignin('base', 'USER_CAN_PICK', canPick);

if state == uint8(0)
    gripperStatus = 0;
    assignin('base', 'USER_VISION_ENABLE', true);

    if holdValid
        currentConfig = holdConfig;
    else
        currentConfig = pickTraj(:,1);
        holdConfig = currentConfig;
        holdValid = true;
    end

    if startGrasp
        assignin('base', 'USER_VISION_ENABLE', false);
        state = uint8(1);
        index = int32(1);
        delay = int32(1);
        waitStableCount = uint16(0);
        holdValid = false;
    end
    return;
end

if state == uint8(1)
    gripperStatus = 0;
    assignin('base', 'USER_VISION_ENABLE', false);
    currentConfig = pickTraj(:, index);
    holdConfig = currentConfig;
    holdValid = true;

    index = index + int32(1);
    if index > nPick
        state = uint8(2);
        index = nPick;
    end

elseif state == uint8(2)
    gripperStatus = 1;
    assignin('base', 'USER_VISION_ENABLE', false);
    currentConfig = pickTraj(:, index);
    holdConfig = currentConfig;
    holdValid = true;

    if targetGrasped
        state = uint8(3);
        index = int32(1);
    end

elseif state == uint8(3)
    gripperStatus = 1;
    assignin('base', 'USER_VISION_ENABLE', false);
    currentConfig = placeTraj(:, index);
    holdConfig = currentConfig;
    holdValid = true;

    index = index + int32(1);
    if index > nPlace
        state = uint8(7);
        index = nPlace;
        delay = int32(1);
    end

elseif state == uint8(7)
    gripperStatus = 1;
    assignin('base', 'USER_VISION_ENABLE', false);
    currentConfig = placeTraj(:, index);
    holdConfig = currentConfig;
    holdValid = true;

    if delay <= DROP_SETTLE_TICKS
        delay = delay + int32(1);
    else
        state = uint8(4);
    end

elseif state == uint8(4)
    gripperStatus = 0;
    assignin('base', 'USER_VISION_ENABLE', false);
    currentConfig = placeTraj(:, index);
    holdConfig = currentConfig;
    holdValid = true;
    state = uint8(5);
    delay = int32(1);

elseif state == uint8(5)
    gripperStatus = 0;
    assignin('base', 'USER_VISION_ENABLE', false);
    currentConfig = placeTraj(:, index);
    holdConfig = currentConfig;
    holdValid = true;

    if delay <= OPEN_SETTLE_TICKS
        delay = delay + int32(1);
        return;
    end

    cubePlaceMode = double(0);
    if evalin('base', 'double(exist(''USER_CUBE_PLACE_MODE'',''var''))') ~= 0
        cubePlaceMode = evalin('base', 'double(USER_CUBE_PLACE_MODE)');
    end

    resetToken = double(0);
    resetToken = evalin('base', 'double(USER_RESET_TOKEN)');

    if cubePlaceMode == 1
        assignin('base', 'USER_CUBE_SECOND_HOME', currentConfig);
        assignin('base', 'USER_CUBE_USE_SECOND_HOME', true);
        assignin('base', 'USER_RESET_TOKEN', resetToken + 1);
        assignin('base', 'USER_AUTO_NEED_RESET', false);
        assignin('base', 'USER_PROCEED', false);
        assignin('base', 'USER_ABORT', false);
        assignin('base', 'USER_VISION_ENABLE', false);

        holdConfig = currentConfig;
        holdValid = true;
        state = uint8(0);
        index = int32(1);
        delay = int32(1);
        waitStableCount = uint16(0);
        return;
    end

    qHomeNow = pickTraj(:,1);
    if cubePlaceMode == 2
        if evalin('base', 'double(exist(''USER_QHOME_CURRENT'',''var''))') ~= 0
            qTmp = zeros(6,1);
            qTmp = evalin('base', 'USER_QHOME_CURRENT');
            if isnumeric(qTmp) && numel(qTmp) == 6 && all(isfinite(qTmp(:)))
                qHomeNow = qTmp;
            end
        end
    end

    viewMoveTraj = interpCols(currentConfig, qHomeNow, RETURN_STEPS);
    viewMoveIndex = int32(1);
    viewMoveMode = uint8(2);
    holdValid = false;
    state = uint8(6);
    index = int32(1);
    delay = int32(1);
    waitStableCount = uint16(0);

elseif state == uint8(6)
    gripperStatus = 0;
    assignin('base', 'USER_VISION_ENABLE', false);
    currentConfig = viewMoveTraj(:, viewMoveIndex);
    holdConfig = currentConfig;
    holdValid = true;

    viewMoveIndex = viewMoveIndex + int32(1);
    if viewMoveIndex > int32(size(viewMoveTraj, 2))
        currentConfig = viewMoveTraj(:, 120);
        holdConfig = currentConfig;
        holdValid = true;

        if viewMoveMode == uint8(2)
            resetToken = double(0);
            resetToken = evalin('base', 'double(USER_RESET_TOKEN)');
            assignin('base', 'USER_RESET_TOKEN', resetToken + 1);
            assignin('base', 'USER_AUTO_NEED_RESET', false);
            assignin('base', 'USER_PROCEED', false);
            assignin('base', 'USER_ABORT', false);
        end

        assignin('base', 'USER_VISION_ENABLE', true);
        state = uint8(0);
        viewMoveIndex = int32(1);
        viewMoveMode = uint8(0);
        waitStableCount = uint16(0);
    end
end
end

function traj = interpCols(qA, qB, n)
qA = qA(:);
qB = qB(:);
traj = zeros(6,120);

if n <= int32(1)
    traj(:,1) = qB;
    return;
end

for i = 1:120
    alpha = double(i-1) / double(n-1);
    traj(:,i) = (1-alpha)*qA + alpha*qB;
end
end
